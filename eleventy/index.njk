<!doctype html>

<html lang="en">
<head>
  <meta charset="utf-8">
  <title>Website of Steve Della Valentina</title>
  <meta name="description" content="Website of Steve Della Valentina">
  <meta name="author" content="Steve Della Valentina">
</head>

{% macro link(page) %}
<a href="#{{ page.slug | slug }}">{{ page.title }}
  {% if page.affinity %}
  <small>{{ page.affinity | dump }}</small>
  {% endif %}
</a>
{% endmacro %}

{% macro nestedLinks(pages) %}
<ul>
{% for page in pages %}
  <li>
    {{ link(page) }}
    {% if page.children %}
    {{ nestedLinks(page.children) }}
    {% endif %}
  </li>
{% endfor %}
</ul>
{% endmacro%}

{% set topPages = pages | rejectattr("parent") | reverse %}

<body>
  <nav>
    {{ nestedLinks(topPages) }}
  </nav>
</body>
</html>
