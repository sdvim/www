{
  "kind": "collectionType",
  "collectionName": "pages",
  "info": {
    "name": "Page",
    "description": ""
  },
  "options": {
    "increments": true,
    "timestamps": true,
    "draftAndPublish": false
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "string",
      "unique": true,
      "required": true
    },
    "emoji": {
      "type": "string",
      "unique": true,
      "required": true
    },
    "description": {
      "type": "string"
    },
    "content": {
      "type": "dynamiczone",
      "components": [
        "content.code",
        "content.media",
        "content.text"
      ]
    },
    "affinity": {
      "type": "component",
      "repeatable": true,
      "component": "metadata.affinity"
    }
  }
}
